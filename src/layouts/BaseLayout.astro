---
import "../styles/global.css";
import { withBase, locales, type Locale } from "@/lib/site";

interface Props {
  title: string;
  description: string;
  locale: Locale;
  page?: "home" | "experience" | "work" | "research" | "recognition" | "contact";
}

const { title, description, locale, page = "home" } = Astro.props;
const nav = {
  en: { home: "Home", experience: "Experience", work: "Portfolio", research: "Research", recognition: "Recognition", contact: "Contact" },
  es: { home: "Inicio", experience: "Experiencia", work: "Portfolio", research: "Investigación", recognition: "Reconocimiento", contact: "Contacto" },
  eu: { home: "Hasiera", experience: "Esperientzia", work: "Portfolioa", research: "Ikerketa", recognition: "Aitorpena", contact: "Kontaktua" }
}[locale];

const pagePath = (targetLocale: Locale, targetPage = page) => {
  const suffix = targetPage === "home" ? "" : `${targetPage}/`;
  return withBase(`/${targetLocale}/${suffix}`);
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase(locales[locale].path)} aria-label="Ander Galisteo">
        <span class="brand-mark">AG</span>
        <span>Ander Galisteo</span>
      </a>
      <nav aria-label="Primary navigation">
        <a class:list={{ active: page === "home" }} href={pagePath(locale, "home")}>{nav.home}</a>
        <a class:list={{ active: page === "experience" }} href={pagePath(locale, "experience")}>{nav.experience}</a>
        <a class:list={{ active: page === "work" }} href={pagePath(locale, "work")}>{nav.work}</a>
        <a class:list={{ active: page === "research" }} href={pagePath(locale, "research")}>{nav.research}</a>
        <a class:list={{ active: page === "recognition" }} href={pagePath(locale, "recognition")}>{nav.recognition}</a>
        <a class:list={{ active: page === "contact" }} href={pagePath(locale, "contact")}>{nav.contact}</a>
        <span class="language-group" aria-label="Language selection">
          {Object.entries(locales).map(([code, info]) => (
            <a class:list={["language", { active: code === locale }]} href={pagePath(code as Locale)}>{info.label}</a>
          ))}
        </span>
      </nav>
    </header>
    <slot />
  </body>
</html>
