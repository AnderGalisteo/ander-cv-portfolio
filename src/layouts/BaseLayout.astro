---
import "../styles/global.css";
import { withBase, locales, type Locale } from "@/lib/site";

interface Props {
  title: string;
  description: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
const nav = {
  en: { experience: "Experience", work: "Work", contact: "Contact" },
  es: { experience: "Experiencia", work: "Trabajo", contact: "Contacto" },
  eu: { experience: "Esperientzia", work: "Lana", contact: "Kontaktua" }
}[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase(locales[locale].path)} aria-label="Ander Galisteo">
        <span class="brand-mark">AG</span>
        <span>Ander Galisteo</span>
      </a>
      <nav aria-label="Primary navigation">
        <a href="#experience">{nav.experience}</a>
        <a href="#work">{nav.work}</a>
        <a href="#contact">{nav.contact}</a>
        <span class="language-group" aria-label="Language selection">
          {Object.entries(locales).map(([code, info]) => (
            <a class:list={["language", { active: code === locale }]} href={withBase(info.path)}>{info.label}</a>
          ))}
        </span>
      </nav>
    </header>
    <slot />
  </body>
</html>
