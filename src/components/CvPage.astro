    currentWork: "Egungo fokua",
    researchWork: "Ikerketa-ibilbidea",
    recognition: "Aitorpena",
    finalTitle: "Sistema industrial seguruak eraikitzea ebidentziarekin, argitasunarekin eta entrega-diziplinarekin.",
    finalText: "Lankidetzetarako, aholkularitzarako edo zibersegurtasun industrialeko programetarako, jarri harremanetan.",
    viewWork: "Lana ikusi",
